# Slack Socket Mode tokens
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_SIGNING_SECRET=your-signing-secret

# Optional runtime credentials
ANTHROPIC_API_KEY=sk-ant-your-key
OPENAI_API_KEY=sk-your-openai-key
HERMES_API_KEY=your-hermes-token
OPENCLAW_API_KEY=your-openclaw-token

# Optional admin API
OPENTAG_ADMIN_TOKEN=change-me
OPENTAG_ADMIN_PORT=8787

# OpenTag
OPENTAG_CONFIG=./examples/opentag.config.example.json
OPENTAG_LOG_LEVEL=info
